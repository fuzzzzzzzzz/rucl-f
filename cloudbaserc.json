{
  "$schema": "https://static.cloudbase.net/cli/cloudbaserc.schema.json",
  "version": "2.0",
  "envId": "cloud1-d4g2ccxaq372d5eb6",
  "functionRoot": "./cloudfunctions",
  "functions": [
    {
      "name": "api",
      "type": "Event",
      "handler": "index.main",
      "timeout": 3,
      "runtime": "Nodejs16.13",
      "memorySize": 256,
      "installDependency": true,
      "envVariables": {
        "STUDENT_HMAC_SECRET": "{{env.STUDENT_HMAC_SECRET}}"
      }
    },
    {
      "name": "processCardImage",
      "type": "Event",
      "handler": "index.main",
      "timeout": 3,
      "runtime": "Nodejs16.13",
      "memorySize": 256,
      "installDependency": true,
      "envVariables": {
        "TENCENT_OCR_REGION": "ap-guangzhou",
        "OCR_DAILY_GLOBAL_LIMIT": "30"
      }
    }
  ]
}
