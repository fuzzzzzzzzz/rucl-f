{
  "$schema": "https://static.cloudbase.net/cli/cloudbaserc.schema.json",
  "version": "2.0",
  "envId": "cloud1-d4g2ccxaq372d5eb6",
  "functionRoot": "./cloudfunctions",
  "functions": [
    {
      "name": "api",
      "type": "Event",
      "handler": "index.main",
      "timeout": 15,
      "runtime": "Nodejs20.19",
      "memorySize": 256,
      "installDependency": true,
      "envVariables": {
        "STUDENT_HMAC_SECRET": "{{env.STUDENT_HMAC_SECRET}}",
        "SUBSCRIPTION_TEMPLATE_ID": "{{env.SUBSCRIPTION_TEMPLATE_ID}}",
        "MINIPROGRAM_STATE": "developer"
      }
    },
    {
      "name": "processCardImage",
      "type": "Event",
      "handler": "index.main",
      "timeout": 20,
      "runtime": "Nodejs20.19",
      "memorySize": 256,
      "installDependency": true,
      "envVariables": {
        "TENCENT_SECRET_ID": "{{env.TENCENT_SECRET_ID}}",
        "TENCENT_SECRET_KEY": "{{env.TENCENT_SECRET_KEY}}",
        "TENCENT_OCR_REGION": "ap-guangzhou",
        "OCR_DAILY_GLOBAL_LIMIT": "30"
      }
    },
    {
      "name": "scheduledCleanup",
      "type": "Event",
      "handler": "index.main",
      "timeout": 60,
      "runtime": "Nodejs20.19",
      "memorySize": 256,
      "installDependency": true,
      "triggers": [
        {
          "name": "dailyCleanup",
          "type": "timer",
          "config": "0 0 3 * * * *"
        }
      ]
    }
  ]
}
