<view class="tab-shell">
  <view wx:for="{{tabs}}" wx:key="pagePath" class="tab {{selected === index ? 'active' : ''}}" data-index="{{index}}" bindtap="switchTab">
    <image class="tab-icon" src="{{selected === index ? item.activeIcon : item.icon}}" mode="aspectFit" />
    <text>{{item.text}}</text>
  </view>
</view>
