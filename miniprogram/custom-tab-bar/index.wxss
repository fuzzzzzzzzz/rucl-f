.tab-shell {
  box-sizing: border-box;
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-top: 5rpx solid #191919;
  box-shadow: 0 -8rpx 0 rgba(25, 25, 25, 0.12);
}
.tab {
  height: 112rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 7rpx;
  border-right: 3rpx solid #191919;
  font-family: Arial, sans-serif;
  font-size: 18rpx;
  font-weight: 900;
}
.tab:last-child {
  border-right: 0;
}
.tab.active {
  background: #ffec00;
}
.tab-icon {
  display: block;
  width: 44rpx;
  height: 44rpx;
}
