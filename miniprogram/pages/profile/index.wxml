<view class="page profile-page">
  <view class="topbar">我的<text class="en">MY ACCOUNT</text></view>
  <view class="user-card"><image src="/assets/user-avatar.jpg" mode="aspectFill" /><view class="user-main"><view class="user-name">{{displayName}}</view><text class="identity">{{category}}</text><view class="number student-number">{{maskedStudentNumber}}</view><view wx:if="{{campus}}" class="campus">中国人民大学 · {{campus}}</view><view class="data-mode">{{dataModeLabel}}</view><view class="identity-state">{{identityStatusLabel}}</view></view></view>
  <view class="stats"><view class="stat" data-type="found" bindtap="goHistory"><view><view class="stat-title">我发布的招领</view><text class="en">MY POSTS</text></view><view class="stat-foot"><view class="count count-red number">{{foundCount}}</view><view class="view-all">查看历史<image src="/assets/icons/chevron-right.png" mode="aspectFit" /></view></view></view><view class="stat" data-type="lost" bindtap="goHistory"><view><view class="stat-title">我登记的失卡</view><text class="en">MY LOST</text></view><view class="stat-foot"><view class="count number">{{lostCount}}</view><view class="view-all">查看历史<image src="/assets/icons/chevron-right.png" mode="aspectFit" /></view></view></view></view>
  <view class="menu-row profile-entry" bindtap="goProfileEdit"><view class="menu-icon"><image src="/assets/icons/badge.png" mode="aspectFit" /></view><view class="menu-copy"><view>我的信息</view><text class="en">PERSONAL INFORMATION</text></view><image class="arrow" src="/assets/icons/chevron-right.png" mode="aspectFit" /></view>
  <view wx:if="{{latestUnreadThanks}}" class="thanks-alert" bindtap="goMessages">
    <view class="thanks-alert-head"><view>你收到新的感谢</view><text class="unread-pill">{{unreadMessageCount}} 条未读</text></view>
    <view class="thanks-alert-body">“{{latestUnreadThanks.body}}”</view>
    <view class="thanks-alert-foot">点击查看消息 <image src="/assets/icons/chevron-right.png" mode="aspectFit" /></view>
  </view>
  <view class="honors"><view class="honor-head"><view class="section-title" bindtap="goThanksWall">校园感谢墙<text class="en">[ THANKS WALL ]</text></view><view class="more" bindtap="goAchievements">全部奖项</view></view><view class="rule" /><view wx:if="{{achievements.length}}" class="badges"><view wx:for="{{achievements}}" wx:key="id"><view class="badge {{item.unlocked ? 'yellow' : 'locked-badge'}}"><image src="{{item.iconPath}}" mode="aspectFit" /></view><b>{{item.name}}</b><text class="award-count number">{{item.progress}}/{{item.target}}</text></view></view><view wx:else class="muted">完成归还任务后，这里会显示你的奖项进度。</view></view>
  <view class="menu-row" bindtap="goMessages"><view class="menu-icon"><image src="/assets/icons/notifications.png" mode="aspectFit" /></view><view class="menu-copy"><view>消息提醒</view><text class="en">NOTIFICATIONS</text></view><text wx:if="{{unreadMessageCount}}" class="notification-count">{{unreadMessageCount}}</text><image class="arrow" src="/assets/icons/chevron-right.png" mode="aspectFit" /></view>
  <view class="menu-row" bindtap="goClaims"><view class="menu-icon"><image src="/assets/icons/verified-user.png" mode="aspectFit" /></view><view class="menu-copy"><view>我的认领</view><text class="en">MY CLAIMS</text></view><image class="arrow" src="/assets/icons/chevron-right.png" mode="aspectFit" /></view>
  <view class="menu-row" bindtap="goSettings"><view class="menu-icon"><image src="/assets/icons/settings.png" mode="aspectFit" /></view><view class="menu-copy"><view>账号设置</view><text class="en">SETTINGS</text></view><image class="arrow" src="/assets/icons/chevron-right.png" mode="aspectFit" /></view>
  <view class="menu-row" bindtap="goHelp"><view class="menu-icon"><image src="/assets/icons/help.png" mode="aspectFit" /></view><view class="menu-copy"><view>帮助中心</view><text class="en">HELP</text></view><image class="arrow" src="/assets/icons/chevron-right.png" mode="aspectFit" /></view>
  <button wx:if="{{isAdmin}}" class="neo-button" bindtap="goAdmin">管理员控制台</button>
</view>
