<view class="page post-page"><view class="topbar">拍照安全发布 / [ CARD SCAN ]</view><view class="scan-box" bindtap="choosePhoto"><image wx:if="{{photoPath}}" mode="aspectFit" src="{{photoPath}}"/><block wx:else><view class="camera">▣</view><view>[ 点击拍摄校园卡 ]</view></block></view><view class="privacy-alert">温馨提示：照片中的头像、完整姓名和学号不会公开显示。</view><text class="label">姓名 [ NAME ]</text><input class="field" placeholder="拍照识别后请检查" bindinput="onName"/><text class="label">学号 [ ID ]</text><input class="field" type="number" maxlength="10" value="{{studentNumber}}" placeholder="10位数字，别人看不到完整号码" bindinput="onNumber"/><text class="label">卡片类别 [ TYPE ]</text><picker range="{{cardCategories}}" value="{{categoryIndex}}" bindchange="onCategoryChange"><view class="field">{{cardCategories[categoryIndex]}}</view></picker><text class="label">学院 [ COLLEGE ]</text><input class="field" placeholder="允许手动填写" bindinput="onCollege"/><text class="label">校区 [ CAMPUS ]</text><picker range="{{campuses}}" range-key="name" value="{{campusIndex}}" bindchange="onCampusChange"><view class="field">{{campuses[campusIndex].name}}</view></picker><text class="label">拾取地点 [ LOCATION ]</text><picker range="{{locations}}" value="{{locationIndex}}" bindchange="onLocationChange"><view class="field">{{locations[locationIndex]}}</view></picker><text class="label">拾取日期 [ DATE ]</text><picker mode="date" bindchange="onDate"><view class="field">{{foundDate || '请选择日期'}}</view></picker><text class="label">卡片特点 [ PRIVATE CLUE ]</text><textarea class="field" placeholder="卡套颜色、贴纸、破损等，只用于确认失主" bindinput="onFeature"/><button class="neo-button neo-button--orange" loading="{{busy}}" bindtap="submit">确认安全发布</button></view>
