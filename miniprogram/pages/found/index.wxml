<view class="page post-page">
  <view class="topbar">拾卡安全发布<text class="en">FOUND CARD POST</text></view>
  <view class="scan-wrap"><view class="scan-box" bindtap="choosePhoto"><image wx:if="{{photoPath}}" class="card-preview" mode="aspectFit" src="{{photoPath}}" /><block wx:else><view class="scan-corner corner-tl" /><view class="scan-corner corner-tr" /><view class="scan-corner corner-bl" /><view class="scan-corner corner-br" /><image class="camera-icon" src="/assets/icons/photo-camera.png" mode="aspectFit" /><view>点击拍摄校园卡</view><text class="en">ALIGN CARD WITH FRAME</text></block></view></view>
  <view class="privacy-alert">{{photoBusy ? '正在识别，原图处理后会立即删除…' : '照片仅用于识别，处理后立即删除，不会公开。'}}</view>

  <text class="label">姓名 <text class="en">[ NAME ]</text></text><input class="field" value="{{name}}" placeholder="拍照识别后请检查" bindinput="onName" />
  <text class="label">学号 <text class="en">[ STUDENT ID ]</text></text><input class="field" type="number" maxlength="10" value="{{studentNumber}}" placeholder="10位数字" bindinput="onNumber" />
  <text class="label">卡片类别 <text class="en">[ TYPE ]</text></text><picker range="{{cardCategories}}" value="{{categoryIndex}}" bindchange="onCategoryChange"><view class="field picker-field">{{cardCategories[categoryIndex]}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker>
  <text class="label">校区 <text class="en">[ CAMPUS ]</text></text><picker range="{{campuses}}" range-key="name" value="{{campusIndex}}" bindchange="onCampusChange"><view class="field picker-field">{{campuses[campusIndex].name}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker>

  <view class="location-panel pickup-panel">
    <view class="section-title">拾取地点<text class="en">[ WHERE YOU FOUND IT ]</text></view><view class="rule" />
    <view class="step-label"><text class="step-number number">1</text>地点类型</view><picker range="{{pickupCategories}}" value="{{pickupCategoryIndex}}" bindchange="onPickupCategoryChange"><view class="field picker-field">{{pickupCategories[pickupCategoryIndex]}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker>
    <view class="step-label"><text class="step-number number">2</text>具体建筑或区域</view><picker range="{{pickupPlaces}}" value="{{pickupPlaceIndex}}" bindchange="onPickupPlaceChange"><view class="field picker-field">{{pickupPlaces[pickupPlaceIndex]}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker>
    <view class="step-label"><text class="step-number number">3</text>楼层或区域</view><picker range="{{pickupAreas}}" value="{{pickupAreaIndex}}" bindchange="onPickupAreaChange"><view class="field picker-field">{{pickupAreas[pickupAreaIndex]}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker>
    <view class="step-label"><text class="step-number number">4</text>具体位置</view><input class="field detail-field" value="{{pickupDetail}}" placeholder="例如：北侧出口旁第三张桌子下" bindinput="onPickupDetail" />
  </view>

  <view class="location-panel storage-panel">
    <view class="section-title">卡片存放地点<text class="en">[ WHERE THE CARD IS NOW ]</text></view><view class="rule" />
    <view class="step-label"><text class="step-number number">1</text>存放地点类型</view><picker range="{{storageCategories}}" value="{{storageCategoryIndex}}" bindchange="onStorageCategoryChange"><view class="field picker-field">{{storageCategories[storageCategoryIndex]}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker>
    <view class="step-label"><text class="step-number number">2</text>具体建筑或交卡点</view><picker range="{{storagePlaces}}" value="{{storagePlaceIndex}}" bindchange="onStoragePlaceChange"><view class="field picker-field">{{storagePlaces[storagePlaceIndex]}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker>
    <view class="step-label"><text class="step-number number">3</text>楼层或服务区域</view><picker range="{{storageAreas}}" value="{{storageAreaIndex}}" bindchange="onStorageAreaChange"><view class="field picker-field">{{storageAreas[storageAreaIndex]}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker>
    <view class="step-label"><text class="step-number number">4</text>具体存放位置</view><input class="field detail-field" value="{{storageDetail}}" placeholder="例如：已交给总服务台工作人员" bindinput="onStorageDetail" />
    <view class="field-tip">姓名学号一致，且有存放照片或卡片已在官方地点后，系统才会向失主显示领取信息。</view>
    <view class="storage-photo" bindtap="chooseStoragePhoto"><image wx:if="{{storagePhotoPath}}" class="storage-preview" src="{{storagePhotoPath}}" mode="aspectFill" /><block wx:else><image class="small-camera" src="/assets/icons/add-a-photo.png" mode="aspectFit" /><view>拍摄存放地点的周围环境</view><text class="en">[ STORAGE AREA PHOTO · OPTIONAL ]</text><text class="photo-help">请拍大范围环境，不要只拍校园卡</text></block></view>
  </view>

  <text class="label">拾取日期 <text class="en">[ DATE ]</text></text><picker mode="date" bindchange="onDate"><view class="field picker-field">{{foundDate || '请选择日期'}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker>
  <text class="label">卡片特点（选填） <text class="en">[ PRIVATE CLUE ]</text></text><textarea class="field feature-field" placeholder="例如：蓝色卡套、背面有贴纸" bindinput="onFeature" />
  <button class="neo-button neo-button--orange submit-button" loading="{{busy}}" bindtap="submit"><view class="submit-main"><image src="/assets/icons/verified-user-white.png" mode="aspectFit" />确认安全发布</view><text class="en">[ SUBMIT ]</text></button>
</view>
