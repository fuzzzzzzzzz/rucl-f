.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
  margin-bottom: 30rpx;
}
.hero-action {
  box-sizing: border-box;
  min-height: 300rpx;
  border: 5rpx solid #191919;
  box-shadow: 9rpx 9rpx 0 #191919;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  font-size: 30rpx;
  font-weight: 900;
}
.hero-action:active {
  transform: translate(5rpx, 5rpx);
  box-shadow: 4rpx 4rpx 0 #191919;
}
.hero-action .en {
  font-size: 17rpx;
  margin-top: 9rpx;
}
.hero-action.lost {
  background: #f04418;
  color: #fff;
}
.hero-action.found {
  background: #ffec00;
}
.action-icon {
  display: block;
  width: 78rpx;
  height: 78rpx;
  margin-bottom: 24rpx;
}
.section-heading {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.section-icon {
  display: block;
  width: 52rpx;
  height: 52rpx;
}
.guide-row {
  display: grid;
  grid-template-columns: 50rpx 1fr;
  gap: 18rpx;
  align-items: start;
  font-size: 27rpx;
  line-height: 1.65;
  margin: 18rpx 0;
}
.guide-number {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  color: #fff;
  background: #191919;
  font-weight: 900;
}
.profile-status {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #efede8;
  border: 4rpx solid #191919;
  padding: 24rpx;
  margin-top: 34rpx;
  font-size: 25rpx;
  line-height: 1.75;
}
.profile-status-copy {
  flex: 1;
  min-width: 0;
}
.profile-status-arrow {
  display: block;
  flex: 0 0 auto;
  width: 42rpx;
  height: 42rpx;
}
.profile-status:active {
  background: #ffec00;
}
.profile-status text {
  display: block;
  color: #6d6861;
  font-size: 22rpx;
}
.empty-profile {
  font-size: 28rpx;
  font-weight: 900;
}
.visual {
  padding: 10rpx;
  position: relative;
}
.visual image {
  display: block;
  width: 100%;
  height: 250rpx;
}
.visual-label {
  position: absolute;
  left: 20rpx;
  bottom: 20rpx;
  background: #191919;
  color: #fff;
  padding: 9rpx 16rpx;
  font-size: 22rpx;
  font-weight: 900;
}
.cloud-error {
  display: flex;
  align-items: center;
  gap: 18rpx;
  border: 5rpx solid #191919;
  background: #f04418;
  color: #fff;
  box-shadow: 8rpx 8rpx 0 #191919;
  padding: 20rpx;
  margin: 0 8rpx 30rpx 0;
}
.cloud-error view {
  flex: 1;
  min-width: 0;
}
.cloud-error text {
  display: block;
  font-size: 21rpx;
  line-height: 1.45;
  margin-top: 4rpx;
}
.cloud-error button {
  flex: 0 0 auto;
  border-radius: 0;
  border: 3rpx solid #191919;
  background: #ffec00;
  font-weight: 900;
}
