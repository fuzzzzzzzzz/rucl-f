.search-page {
  background-image: linear-gradient(
    135deg,
    transparent 74%,
    rgba(25, 25, 25, 0.055) 74%,
    rgba(25, 25, 25, 0.055) 75%,
    transparent 75%
  );
}
.match {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 31rpx;
}
.match .en {
  display: block;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  margin-top: 5rpx;
}
.match-banner {
  border: 5rpx solid #191919;
  box-shadow: 9rpx 9rpx 0 #191919;
  background: #18d9aa;
  padding: 27rpx 25rpx;
  margin: 28rpx 9rpx 40rpx 0;
  display: flex;
  gap: 20rpx;
  align-items: center;
  font-size: 29rpx;
  font-weight: 900;
}
.match-banner .en {
  display: block;
  font-size: 17rpx;
  margin-top: 4rpx;
  letter-spacing: 2rpx;
}
.verify-icon {
  display: block;
  flex: 0 0 auto;
  width: 54rpx;
  height: 54rpx;
}
.locked {
  position: relative;
  overflow: hidden;
  min-height: 270rpx;
  border: 5rpx dashed #191919;
  box-shadow: 9rpx 9rpx 0 #191919;
  background: #deddd9;
  display: flex;
  align-items: center;
  justify-content: center;
}
.mosaic {
  position: absolute;
  inset: -12rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  opacity: 0.55;
  filter: blur(4rpx);
  animation: mosaic-wave 2.4s ease-in-out infinite alternate;
}
.mosaic-block:nth-child(3n + 1) {
  background: #999;
}
.mosaic-block:nth-child(3n + 2) {
  background: #c8c8c8;
}
.mosaic-block:nth-child(3n) {
  background: #777;
}
.locked-copy {
  position: relative;
  z-index: 2;
  padding: 28rpx;
  background: rgba(250, 248, 242, 0.88);
  border: 4rpx solid #191919;
  text-align: center;
  font-size: 27rpx;
  font-weight: 900;
}
.lock-icon {
  display: block;
  width: 58rpx;
  height: 58rpx;
  margin: 0 auto 12rpx;
}
.locked-copy .en {
  display: block;
  margin-top: 9rpx;
  font-size: 17rpx;
  letter-spacing: 2rpx;
}
@keyframes mosaic-wave {
  0% {
    transform: translate3d(-3%, -2%, 0) scale(1.04);
    opacity: 0.42;
  }
  50% {
    transform: translate3d(3%, 2%, 0) scale(1.1);
    opacity: 0.72;
  }
  100% {
    transform: translate3d(-1%, 3%, 0) scale(1.06);
    opacity: 0.5;
  }
}
.results {
  margin-top: 48rpx;
}
.result-heading {
  margin-bottom: 20rpx;
}
.empty-result {
  font-size: 27rpx;
  line-height: 1.7;
}
.register-entry {
  box-sizing: border-box;
  width: 100%;
  min-height: 100rpx;
  margin-top: 24rpx;
  padding: 16rpx 20rpx;
  border: 4rpx solid #191919;
  border-radius: 0;
  background: #ffec00;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #191919;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
}
.register-entry::after {
  border: 0;
}
.register-entry image {
  display: block;
  width: 48rpx;
  height: 48rpx;
}
.register-entry text {
  display: block;
}
.register-entry .en {
  margin-top: 4rpx;
  font-size: 15rpx;
  letter-spacing: 2rpx;
}
.registered-tip {
  margin-top: 22rpx;
  padding: 18rpx;
  border: 3rpx solid #191919;
  background: #18d9aa;
  font-size: 23rpx;
  font-weight: 900;
}
.registration-card {
  background: #fff9c8;
}
.registration-card .label {
  font-size: 25rpx;
}
.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.picker-field image {
  display: block;
  width: 42rpx;
  height: 42rpx;
}
.short-textarea {
  height: 130rpx;
}
.registration-note {
  margin-top: 20rpx;
  color: #6d6861;
  font-size: 22rpx;
  line-height: 1.55;
}
.register-submit {
  width: 100%;
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.register-submit .en {
  display: block;
  margin-top: 5rpx;
  font-size: 16rpx;
  letter-spacing: 2rpx;
}
.result-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 34rpx;
  font-weight: 900;
}
.result-type {
  background: #ffec00;
  border: 3rpx solid #191919;
  padding: 7rpx 12rpx;
  font-size: 21rpx;
}
.result-card > .number {
  margin: 18rpx 0;
  font-size: 31rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}
.result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.result-meta text {
  border: 3rpx solid #191919;
  padding: 6rpx 10rpx;
  font-size: 21rpx;
}
.result-note {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 3rpx solid #191919;
  color: #6d6861;
  font-size: 23rpx;
  line-height: 1.55;
}
.official-point {
  margin-top: 22rpx;
  padding: 20rpx;
  border: 4rpx solid #191919;
  background: #ffec00;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.55;
}
.official-point text {
  display: block;
}
.official-label {
  margin-bottom: 8rpx;
  font-size: 21rpx;
}
.pickup-tip {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 3rpx solid #191919;
  font-size: 21rpx;
  font-weight: 400;
}
