<view class="page edit-page"><view class="topbar">我的信息<text class="en">PERSONAL INFORMATION</text></view><view class="notice"><view>姓名和学号会一起核对。</view><view>其他人只能看到隐藏后的信息。</view><view>这不是学校官方身份认证。</view></view><text class="label">姓名 <text class="en">[ NAME ]</text></text><input class="field" value="{{name}}" placeholder="请输入校园卡上的姓名" bindinput="onName" /><text class="label">学号 <text class="en">[ STUDENT ID ]</text></text><input class="field" type="number" maxlength="10" value="{{studentNumber}}" placeholder="请输入10位学号" bindinput="onNumber" /><text class="label">卡片类别 <text class="en">[ TYPE ]</text></text><picker range="{{cardCategories}}" value="{{categoryIndex}}" bindchange="onCategoryChange"><view class="field picker-field">{{cardCategories[categoryIndex]}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker><text class="label">常用校区 <text class="en">[ CAMPUS ]</text></text><picker range="{{campuses}}" range-key="name" value="{{campusIndex}}" bindchange="onCampusChange"><view class="field picker-field">{{campuses[campusIndex].name}}<image class="picker-icon" src="/assets/icons/expand-more.png" mode="aspectFit" /></view></picker><button class="neo-button save-button" loading="{{busy}}" bindtap="save">保存信息<text class="en">[ SAVE ]</text></button></view>
