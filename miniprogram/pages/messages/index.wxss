.empty-message {
  font-size: 27rpx;
  line-height: 1.6;
}
.message-card {
  background: #fff9c8;
}
.message-card.read {
  background: #fff;
}
.message-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 29rpx;
  font-weight: 900;
}
.message-head image {
  display: block;
  width: 48rpx;
  height: 48rpx;
}
.message-body {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 3rpx solid #191919;
  font-size: 25rpx;
  line-height: 1.65;
}
.message-time {
  margin-top: 14rpx;
  color: #6d6861;
  font-size: 19rpx;
}
