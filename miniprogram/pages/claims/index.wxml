<view class="page claims-page">
  <view class="topbar">我的认领<text class="en">MY CLAIMS</text></view>
  <view wx:if="{{loading}}" class="neo-card empty-state">正在读取认领记录…</view>
  <view wx:elif="{{error}}" class="neo-card empty-state error-state">{{error}}<button class="retry" bindtap="loadClaims">重新读取</button></view>
  <view wx:elif="{{claims.length === 0}}" class="neo-card empty-state">目前还没有认领申请。</view>
  <view wx:for="{{claims}}" wx:key="id" class="neo-card claim-card">
    <view class="claim-head"><view><view class="claim-name">{{item.maskedName}} · {{item.category}}</view><view class="number">{{item.maskedStudentNumber}}</view></view><view class="claim-status status-{{item.status}}">{{item.statusText}}</view></view>
    <view class="claim-meta"><text>{{item.campusName}}</text><text>{{item.createdAt}}</text></view>
    <view wx:if="{{item.officialStoragePoint}}" class="handover-point"><b>卡片存放地点</b><text>{{item.officialStoragePoint}}</text><small>请按页面提示前往存放地点，取到卡后拍照确认完成。</small></view>
    <image wx:if="{{item.storagePhotoUrl}}" class="storage-photo" src="{{item.storagePhotoUrl}}" mode="aspectFill" />
    <view wx:elif="{{item.status === 'awaiting_official_transfer'}}" class="claim-note">拾卡者还未上传可辨认的存放环境照片。上传照片或转交官方地点后，系统会显示领取信息。</view>
    <view wx:elif="{{item.status === 'admin_review'}}" class="claim-note">该记录存在异常或争议，管理员处理完成前不会展示存放地点和照片。</view>
    <view wx:if="{{item.status === 'ready_for_pickup'}}" class="complete-panel">
      <view class="proof-title">领取后，请现场拍摄校园卡</view>
      <view class="proof-help">该照片只是交接记录，不代表学校身份核验；发生争议时由管理员处理。</view>
      <view class="proof-camera" data-id="{{item.id}}" bindtap="chooseProof">
        <image wx:if="{{proofPaths[item.id]}}" src="{{proofPaths[item.id]}}" mode="aspectFill" />
        <block wx:else><image src="/assets/icons/photo-camera.png" mode="aspectFit" /><text>现场拍摄已取到的卡</text></block>
      </view>
      <textarea class="thanks-input" data-id="{{item.id}}" maxlength="30" placeholder="给拾卡同学一句感谢（选填，最多30字）" bindinput="onThanks" />
      <button class="complete-button" data-id="{{item.id}}" loading="{{busyId === item.id}}" disabled="{{busyId}}" bindtap="confirmReceived">我已取到卡，完成任务</button>
    </view>
  </view>
</view>
