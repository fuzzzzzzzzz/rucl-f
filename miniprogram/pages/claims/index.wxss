.empty-state {
  line-height: 1.7;
}
.retry {
  margin-top: 20rpx;
  border: 4rpx solid #191919;
  border-radius: 0;
  background: #ffec00;
  font-weight: 900;
}
.claim-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}
.claim-name {
  font-size: 29rpx;
  font-weight: 900;
}
.claim-head .number {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 900;
}
.claim-status {
  align-self: flex-start;
  padding: 8rpx 12rpx;
  border: 3rpx solid #191919;
  background: #ffec00;
  font-size: 20rpx;
  font-weight: 900;
}
.status-approved,
.status-returned {
  background: #18d9aa;
}
.status-rejected {
  background: #efede8;
}
.claim-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  color: #6d6861;
  font-size: 22rpx;
}
.handover-point,
.claim-note {
  margin-top: 22rpx;
  padding: 20rpx;
  border: 4rpx solid #191919;
  background: #ffec00;
  line-height: 1.6;
}

.storage-photo {
  box-sizing: border-box;
  display: block;
  width: 100%;
  height: auto;
  margin-top: 20rpx;
  border: 4rpx solid #191919;
}

.photo-preview-hint {
  margin-top: 10rpx;
  color: #5f5a54;
  font-size: 21rpx;
  font-weight: 700;
  text-align: center;
}

.complete-panel {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 3rpx solid #191919;
}

.proof-title {
  font-weight: 900;
}

.proof-help {
  margin-top: 8rpx;
  color: #5f5a54;
  font-size: 21rpx;
  line-height: 1.6;
}

.proof-camera {
  display: flex;
  min-height: 220rpx;
  margin-top: 18rpx;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed #191919;
  background: #efede8;
  font-weight: 900;
}

.proof-camera > image {
  width: 64rpx;
  height: 64rpx;
  margin-right: 12rpx;
}

.proof-camera > image:first-child:last-child {
  width: 100%;
  height: 300rpx;
  margin: 0;
}

.thanks-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 120rpx;
  margin-top: 18rpx;
  padding: 18rpx;
  border: 4rpx solid #191919;
  background: #fff;
}

.complete-button {
  margin-top: 18rpx;
  border: 4rpx solid #191919;
  border-radius: 0;
  box-shadow: 7rpx 7rpx 0 #191919;
  background: #18d9aa;
  font-weight: 900;
}
.handover-point b,
.handover-point text,
.handover-point small {
  display: block;
}
.handover-point small {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 3rpx solid #191919;
  font-size: 20rpx;
}
.claim-note {
  background: #efede8;
  font-size: 22rpx;
}
