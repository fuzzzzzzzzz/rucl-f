page {
  background: #faf8f2;
  color: #191919;
  font-family: SimHei, 'Microsoft YaHei', Arial, sans-serif;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 30rpx 28rpx 150rpx;
}

.en,
.number,
input,
textarea {
  font-family: Arial, sans-serif;
}

.topbar {
  margin: -30rpx -28rpx 38rpx;
  padding: 30rpx 32rpx 28rpx;
  background: #191919;
  color: #fff;
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.topbar .en {
  display: block;
  margin-top: 6rpx;
  color: #ffec00;
  font-size: 19rpx;
  letter-spacing: 3rpx;
}

.neo-card {
  box-sizing: border-box;
  background: #fff;
  border: 5rpx solid #191919;
  box-shadow: 9rpx 9rpx 0 #191919;
  padding: 28rpx;
  margin: 24rpx 9rpx 36rpx 0;
}

.neo-button {
  box-sizing: border-box;
  border-radius: 0;
  border: 5rpx solid #191919;
  background: #ffec00;
  color: #191919;
  font-weight: 900;
  line-height: 1.25;
  min-height: 100rpx;
  padding: 20rpx 24rpx;
  box-shadow: 8rpx 8rpx 0 #191919;
  margin: 22rpx 8rpx 30rpx 0;
}

.neo-button:active {
  transform: translate(5rpx, 5rpx);
  box-shadow: 3rpx 3rpx 0 #191919;
}

.neo-button::after {
  border: 0;
}

.neo-button--orange {
  background: #f04418;
  color: #fff;
}

.field {
  box-sizing: border-box;
  width: 100%;
  min-height: 92rpx;
  background: #fff;
  border: 5rpx solid #191919;
  padding: 22rpx 26rpx;
  margin-top: 12rpx;
  font-size: 29rpx;
}

.label {
  display: block;
  font-size: 27rpx;
  font-weight: 900;
  margin-top: 28rpx;
}

.label .en {
  font-size: 19rpx;
  letter-spacing: 2rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.section-title .en {
  display: block;
  font-size: 19rpx;
  letter-spacing: 2rpx;
}

.rule {
  height: 5rpx;
  background: #191919;
  margin: 16rpx 0 24rpx;
}

.muted {
  color: #6d6861;
}
